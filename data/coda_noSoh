    def apply_title(ws, title, start_row=1, end_col=10):
        ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=end_col)
        c = ws.cell(start_row, 1)
        c.value = title
        c.fill = header_fill
        c.font = Font(color=COLOR_WHITE, bold=True, size=14)
        c.alignment = Alignment(horizontal="center", vertical="center")
        ws.row_dimensions[start_row].height = 24

    def style_header(ws, row_idx, start_col=1, end_col=None):
        if end_col is None:
            end_col = ws.max_column
        for col in range(start_col, end_col + 1):
            cell = ws.cell(row_idx, col)
            cell.fill = header_fill
            cell.font = Font(color=COLOR_WHITE, bold=True)
            cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
            cell.border = Border(bottom=thin_side)

    def style_subheader(ws, row_idx, start_col=1, end_col=None):
        if end_col is None:
            end_col = ws.max_column
        for col in range(start_col, end_col + 1):
            cell = ws.cell(row_idx, col)
            cell.fill = sub_fill
            cell.font = Font(bold=True)
            cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)

    def style_data_area(ws, start_row, end_row, start_col=1, end_col=None):
        if end_col is None:
            end_col = ws.max_column
        for r in range(start_row, end_row + 1):
            for c in range(start_col, end_col + 1):
                cell = ws.cell(r, c)
                cell.border = Border(bottom=thin_side)
                if c == 1:
                    cell.alignment = Alignment(horizontal="left", vertical="center")
                else:
                    cell.alignment = Alignment(horizontal="center", vertical="center")

    def set_number_formats(ws, header_row, start_row):
        header_map = {ws.cell(header_row, c).value: c for c in range(1, ws.max_column + 1)}
        pct_keywords = ["Ao", "share", "rate", "pct"]
        int_keywords = ["count", "items", "units", "selected", "flag", "stock", "level"]
        currency_keywords = ["cost", "price", "KRW"]
        hours_keywords = ["_h", "Hours", "wait", "restore", "diag", "lead", "time"]

        for name, col_idx in header_map.items():
            if name is None:
                continue
            name_str = str(name)

            fmt = None
            if any(k.lower() in name_str.lower() for k in currency_keywords):
                fmt = '#,##0'
            elif any(k.lower() in name_str.lower() for k in pct_keywords):
                fmt = '0.0000'
            elif any(k.lower() in name_str.lower() for k in hours_keywords):
                fmt = '0.00'
            elif any(k.lower() in name_str.lower() for k in int_keywords):
                fmt = '0'
            else:
                fmt = '0.0000'

            for r in range(start_row, ws.max_row + 1):
                ws.cell(r, col_idx).number_format = fmt

    def autofit(ws, min_width=10, max_width=28):
        for col_cells in ws.columns:
            col_idx = col_cells[0].column
            length = 0
            for cell in col_cells:
                try:
                    value = "" if cell.value is None else str(cell.value)
                except Exception:
                    value = ""
                length = max(length, len(value))
            ws.column_dimensions[get_column_letter(col_idx)].width = min(max(length + 2, min_width), max_width)

    def write_df_sheet(sheet_name, df, title):
        ws = wb.create_sheet(sheet_name)
        apply_title(ws, title, start_row=1, end_col=max(8, len(df.columns)))
