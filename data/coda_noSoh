        ws_readme[f"A{idx}"] = v
    autofit(ws_readme)

    ws_summary = write_df_sheet("Scenario_Summary", compare_summary_df, "Representative Target Scenario Summary")
    ws_target_raw = write_df_sheet("Target_Sweep_Raw", target_sweep_raw_df, "Target Sweep Raw Data")
    ws_part = write_df_sheet("Part_Comparison", part_compare_enriched_df, "Part-level Comparison (Raw + Enriched)")
    ws_with = write_df_sheet("WITH_SOH_ENV_Detail", with_diag, "WITH_SOH_ENV Representative Detail")
    ws_without = write_df_sheet("WITHOUT_SOH_ENV_Detail", without_diag, "WITHOUT_SOH_ENV Representative Detail")
    ws_with_sel = write_df_sheet("WITH_Selected", with_selected_df, "Selected Parts - WITH_SOH_ENV")
    ws_without_sel = write_df_sheet("WITHOUT_Selected", without_selected_df, "Selected Parts - WITHOUT_SOH_ENV")
    ws_integrated = write_df_sheet("Integrated_Raw", integrated_raw_df, "Integrated Pareto / Solution Raw Data")

    # -----------------------------
    # 20-4) Part_Comparison formula columns
    # -----------------------------
    part_headers = [ws_part.cell(2, c).value for c in range(1, ws_part.max_column + 1)]
    part_col = {name: idx + 1 for idx, name in enumerate(part_headers)}

    extra_cols = [
        "with_only_selected",
        "without_only_selected",
        "both_selected",
        "stock_delta_formula",
        "impact_delta_formula"
    ]
    start_extra = ws_part.max_column + 1
    for i, name in enumerate(extra_cols, start=start_extra):
        ws_part.cell(2, i).value = name
    style_header(ws_part, 2, start_extra, start_extra + len(extra_cols) - 1)

    row_start = 3
    row_end = ws_part.max_row
    for r in range(row_start, row_end + 1):
        e = get_column_letter(part_col["selected_with_soh_env"])
        f = get_column_letter(part_col["selected_without_soh_env"])
        g = get_column_letter(part_col["stock_with_soh_env"])
        h = get_column_letter(part_col["stock_without_soh_env"])
        w = get_column_letter(part_col["ao_impact_with_soh_env"])
        x = get_column_letter(part_col["ao_impact_without_soh_env"])

        ws_part.cell(r, start_extra + 0).value = f'=IF(AND({e}{r}=1,{f}{r}=0),1,0)'
        ws_part.cell(r, start_extra + 1).value = f'=IF(AND({e}{r}=0,{f}{r}=1),1,0)'
        ws_part.cell(r, start_extra + 2).value = f'=IF(AND({e}{r}=1,{f}{r}=1),1,0)'
        ws_part.cell(r, start_extra + 3).value = f'={h}{r}-{g}{r}'
        ws_part.cell(r, start_extra + 4).value = f'={x}{r}-{w}{r}'

    style_data_area(ws_part, 3, ws_part.max_row, start_extra, ws_part.max_column)
    set_number_formats(ws_part, header_row=2, start_row=3)
    autofit(ws_part)

    # -----------------------------
    # 20-5) Target_Compare sheet
    # -----------------------------
    ws_tc = wb.create_sheet("Target_Compare")
    apply_title(ws_tc, "Target-wise Comparison (WITH vs WITHOUT)", start_row=1, end_col=14)

    tc_headers = [
        "target_ao",
        "cost_min_with", "cost_min_without", "cost_delta_without_minus_with",
        "ao_max_with", "ao_max_without", "ao_delta_without_minus_with",
        "managed_max_with", "managed_max_without", "managed_delta_without_minus_with",
        "share_with", "share_without", "share_delta_without_minus_with"
    ]
    for i, h in enumerate(tc_headers, start=1):
        ws_tc.cell(2, i).value = h
    style_header(ws_tc, 2)

    target_vals = sorted(target_compare_df["target_ao"].tolist())
    for i, target in enumerate(target_vals, start=3):
        ws_tc.cell(i, 1).value = target
        # with block
        base_idx = i - 2
        ws_tc.cell(i, 2).value = target_compare_df.loc[base_idx - 1, "cost_min_with_soh_env"]
        ws_tc.cell(i, 3).value = target_compare_df.loc[base_idx - 1, "cost_min_without_soh_env"]
        ws_tc.cell(i, 4).value = f"=C{i}-B{i}"

        ws_tc.cell(i, 5).value = target_compare_df.loc[base_idx - 1, "ao_max_with_soh_env"]
        ws_tc.cell(i, 6).value = target_compare_df.loc[base_idx - 1, "ao_max_without_soh_env"]
        ws_tc.cell(i, 7).value = f"=F{i}-E{i}"

        ws_tc.cell(i, 8).value = target_compare_df.loc[base_idx - 1, "managed_max_with_soh_env"]
        ws_tc.cell(i, 9).value = target_compare_df.loc[base_idx - 1, "managed_max_without_soh_env"]
        ws_tc.cell(i, 10).value = f"=I{i}-H{i}"

        ws_tc.cell(i, 11).value = target_compare_df.loc[base_idx - 1, "share_ge_target_with_soh_env"]
        ws_tc.cell(i, 12).value = target_compare_df.loc[base_idx - 1, "share_ge_target_without_soh_env"]
        ws_tc.cell(i, 13).value = f"=L{i}-K{i}"

    style_data_area(ws_tc, 3, ws_tc.max_row)
    ws_tc.freeze_panes = "A3"
    ws_tc.auto_filter.ref = ws_tc.dimensions
    set_number_formats(ws_tc, header_row=2, start_row=3)
    autofit(ws_tc)

    # -----------------------------
    # 20-6) Dashboard sheet
    # -----------------------------
    ws_dash = wb.create_sheet("Dashboard")
    apply_title(ws_dash, "Integrated Dashboard | WITH_SOH_ENV vs WITHOUT_SOH_ENV", start_row=1, end_col=12)

    ws_dash["A3"] = "대표 Target"
    ws_dash["B3"] = "=Scenario_Summary!B3"
    ws_dash["D3"] = "실험 요약"
    ws_dash["E3"] = "SOH_SCORE + Env_resistance 제거 영향 비교"
    for cell_ref in ["A3", "D3"]:
        ws_dash[cell_ref].fill = sub_fill
        ws_dash[cell_ref].font = Font(bold=True)

    kpi_labels = [
        ("A5", "Best Ao"),
        ("A6", "Total Cost"),
        ("A7", "Managed Parts"),
        ("A8", "Total Stock Units"),
        ("A9", "Selected Pre-buy"),
        ("A10", "Selected Protection"),
        ("A11", "Candidate Count"),
        ("A12", "Spare Demand Count"),
    ]
    for ref, label in kpi_labels:
        ws_dash[ref] = label
        ws_dash[ref].fill = gray_fill
        ws_dash[ref].font = Font(bold=True)

    ws_dash["B4"] = "WITH_SOH_ENV"
    ws_dash["C4"] = "WITHOUT_SOH_ENV"
    ws_dash["D4"] = "Delta (Without - With)"
    style_subheader(ws_dash, 4, 2, 4)

    summary_row_with = 3
    summary_row_without = 4
    metric_map = {
        5: ("C", "D"),
        6: ("D", "E"),
        7: ("E", "F"),
        8: ("F", "G"),
        9: ("G", "H"),
        10: ("H", "I"),
        11: ("I", "J"),
        12: ("J", None),
    }

    for dash_row, (col_with, col_without) in metric_map.items():
        ws_dash[f"B{dash_row}"] = f"=Scenario_Summary!{col_with}{summary_row_with}"
        if col_without is not None:
            ws_dash[f"C{dash_row}"] = f"=Scenario_Summary!{col_with}{summary_row_without}"
            ws_dash[f"D{dash_row}"] = f"=C{dash_row}-B{dash_row}"
        else:
            ws_dash[f"C{dash_row}"] = f"=Scenario_Summary!{col_with}{summary_row_without}"
            ws_dash[f"D{dash_row}"] = f"=C{dash_row}-B{dash_row}"

    for row in range(5, 13):
        for col in range(2, 5):
            ws_dash.cell(row, col).fill = kpi_fill

    ws_dash["F5"] = "선택 변화 요약"
    ws_dash["F5"].fill = sub_fill
    ws_dash["F5"].font = Font(bold=True)

    ws_dash["F6"] = "WITH에서만 선택"
    ws_dash["G6"] = f"=SUM(Part_Comparison!{get_column_letter(start_extra)}3:{get_column_letter(start_extra)}{row_end})"
    ws_dash["F7"] = "WITHOUT에서만 선택"
    ws_dash["G7"] = f"=SUM(Part_Comparison!{get_column_letter(start_extra+1)}3:{get_column_letter(start_extra+1)}{row_end})"
    ws_dash["F8"] = "양쪽 모두 선택"
    ws_dash["G8"] = f"=SUM(Part_Comparison!{get_column_letter(start_extra+2)}3:{get_column_letter(start_extra+2)}{row_end})"
    ws_dash["F9"] = "선택 여부 변경 개수"
    selection_changed_col = get_column_letter(part_col["selection_changed"])
    ws_dash["G9"] = f"=SUM(Part_Comparison!{selection_changed_col}3:{selection_changed_col}{row_end})"
    ws_dash["F10"] = "재고 증가(Without>With)"
    stock_delta_col = get_column_letter(start_extra + 3)
    ws_dash["G10"] = f'=COUNTIF(Part_Comparison!{stock_delta_col}3:{stock_delta_col}{row_end},">0")'
    ws_dash["F11"] = "재고 감소(Without<With)"
    ws_dash["G11"] = f'=COUNTIF(Part_Comparison!{stock_delta_col}3:{stock_delta_col}{row_end},"<0")'
    ws_dash["F12"] = "Ao impact 증가 부품수"
    impact_delta_col = get_column_letter(start_extra + 4)
    ws_dash["G12"] = f'=COUNTIF(Part_Comparison!{impact_delta_col}3:{impact_delta_col}{row_end},">0")'
    for r in range(6, 13):
        ws_dash[f"F{r}"].fill = gray_fill
        ws_dash[f"F{r}"].font = Font(bold=True)
        ws_dash[f"G{r}"].fill = caution_fill

    ws_dash["A15"] = "해석 가이드"
    ws_dash["A15"].fill = sub_fill
    ws_dash["A15"].font = Font(bold=True)
    guide_rows = [
        "1) Delta(Without-With)가 음수면 SOH/환경 제거 후 값이 감소한 것",
        "2) WITH에서만 선택된 품목은 aging 반영 시 중요도가 올라간 부품 후보",
        "3) WITHOUT에서만 선택된 품목은 aging 제거 후 상대 우선순위가 올라간 부품 후보",
        "4) Target_Compare 시트에서 target별 비용/Ao/관리부품 수 변화 확인",
    ]
    for i, txt in enumerate(guide_rows, start=16):
        ws_dash[f"A{i}"] = txt

    # Charts
    line_cost = LineChart()
    line_cost.title = "Min Cost by Target"
    line_cost.y_axis.title = "Total Cost"
    line_cost.x_axis.title = "Target Ao"
    data = Reference(ws_tc, min_col=2, max_col=3, min_row=2, max_row=ws_tc.max_row)
    cats = Reference(ws_tc, min_col=1, min_row=3, max_row=ws_tc.max_row)
    line_cost.add_data(data, titles_from_data=True)
    line_cost.set_categories(cats)
    line_cost.height = 7
    line_cost.width = 11
    ws_dash.add_chart(line_cost, "I4")

    line_ao = LineChart()
    line_ao.title = "Best Ao by Target"
    line_ao.y_axis.title = "Ao"
    line_ao.x_axis.title = "Target Ao"
    data2 = Reference(ws_tc, min_col=5, max_col=6, min_row=2, max_row=ws_tc.max_row)
    line_ao.add_data(data2, titles_from_data=True)
    line_ao.set_categories(cats)
    line_ao.height = 7
    line_ao.width = 11
    ws_dash.add_chart(line_ao, "I20")

    bar_parts = BarChart()
    bar_parts.type = "col"
    bar_parts.title = "Managed Parts / Stock Units"
    bar_parts.y_axis.title = "Count"
    bar_data = Reference(ws_dash, min_col=2, max_col=3, min_row=7, max_row=8)
    bar_cats = Reference(ws_dash, min_col=1, min_row=7, max_row=8)
    bar_parts.add_data(bar_data, titles_from_data=False)
    bar_parts.set_categories(bar_cats)
    bar_parts.height = 7
    bar_parts.width = 11
    ws_dash.add_chart(bar_parts, "I36")

    # Number formats
    for cell in ["B5", "C5", "D5"]:
        ws_dash[cell].number_format = "0.0000"
    for row in range(6, 13):
        for col in ["B", "C", "D", "G"]:
            ws_dash[f"{col}{row}"].number_format = '#,##0'
    ws_dash.freeze_panes = "A4"
    autofit(ws_dash)

    # -----------------------------
    # 20-7) Final workbook polish
    # -----------------------------
    for ws in wb.worksheets:
        ws.sheet_view.showGridLines = False

    wb.save(output_path)
    print(f"[EXPORT] {output_path}")


