        sc = plt.scatter(
            df_unique["Ao"] * 100.0,
            df_unique["total_cost"],
            c=df_unique["target_ao"],
            s=28,
            alpha=0.75
        )

        for ao_line in AO_LINES:
            plt.axvline(
                ao_line * 100.0,
                linestyle="--",
                linewidth=1.0,
                alpha=0.6
            )

        plt.xlabel("Ao (%)")
        plt.ylabel("Total Cost (KRW)")
        plt.title("Integrated Target-Sweep Trade-off Map (%)")
        plt.grid(True, alpha=0.25)
